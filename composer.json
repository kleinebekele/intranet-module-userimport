{
    "name": "do1emu/module-userimport",
    "description": "Benutzer-Import-Modul für die modulare Intranet-Plattform: CSV-Import mit Rollen und Einladungslink. https://github.com/kleinebekele/intranet-core",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "intranet", "modul", "import", "users"],
    "authors": [
        {
            "name": "do1emu"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Intranet\\Modules\\UserImport\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Intranet\\Modules\\UserImport\\UserImportServiceProvider"
            ]
        }
    }
}
